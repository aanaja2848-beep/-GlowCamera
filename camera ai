<body>
    <div class="container">
        <div class="camera-wrapper">
            <video id="video" autoplay playsinline></video>
            <canvas id="canvas"></canvas>
        </div>
        
        <div class="controls">
            <div class="effect-buttons">
                <button class="effect-btn" data-effect="none">Normal</button>
                <button class="effect-btn active" data-effect="glow">Glow Parah</button>
                <button class="effect-btn" data-effect="beauty">Ganteng</button>
                <button class="effect-btn" data-effect="golden">Golden Glow</button>
                <button class="effect-btn" data-effect="neon">Neon Glow</button>
            </div>
            
            <div class="slider-container">
                <label>Intensitas Glow: <span id="intensityValue">70</span>%</label>
                <input type="range" id="intensity" min="0" max="100" value="70">
            </div>
            
            <div class="action-buttons">
                <button class="action-btn capture-btn" id="captureBtn">📸 Ambil Foto</button>
                <button class="action-btn reset-btn" id="resetBtn">🔄 Reset</button>
            </div>
            
            <div class="result" id="result" style="display: none;">
                <h4>Hasil Foto Glowing!</h4>
                <img id="resultImage" alt="Hasil foto">
                <button class="download-btn" id="downloadBtn">💾 Download Foto</button>
            </div>
        </div>
    </div>

